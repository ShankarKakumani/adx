#!/usr/bin/env bash

# adx — Android Developer eXperience
# WiFi connect + scrcpy mirror for Android 11+ devices

set -euo pipefail

ADX_VERSION="1.2.4"
ADX_REPO="ShankarKakumani/adx"
ADX_DIR="${HOME}/.adx"
ADX_HISTORY="${ADX_DIR}/history"
ADX_LABELS="${ADX_DIR}/labels"

mkdir -p "$ADX_DIR"
touch "$ADX_HISTORY" "$ADX_LABELS"

# ---------------------------------------------------------------------------
# Colors & formatting
# ---------------------------------------------------------------------------
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'
GREEN='\033[32m'
YELLOW='\033[33m'
BLUE='\033[34m'
CYAN='\033[36m'
RED='\033[31m'
WHITE='\033[97m'

_print()   { printf "%b\n" "$1"; }
_success() { printf "  ${GREEN}✓${RESET} %b\n" "$1"; }
_warn()    { printf "  ${YELLOW}!${RESET} %b\n" "$1"; }
_error()   { printf "  ${RED}✗${RESET} %b\n" "$1"; }
_info()    { printf "  ${DIM}%b${RESET}\n" "$1"; }
_header()  { printf "\n  ${BOLD}${WHITE}%b${RESET}\n\n" "$1"; }

_spinner() {
    local pid=$1 msg="$2"
    local frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
    local i=0
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r  ${CYAN}${frames[$i]}${RESET} %s" "$msg" >&2
        i=$(( (i + 1) % ${#frames[@]} ))
        sleep 0.1
    done
    printf "\r\033[K" >&2
}

# ---------------------------------------------------------------------------
# Platform detection
# ---------------------------------------------------------------------------
ADX_OS="unknown"
case "$(uname -s)" in
    Darwin*) ADX_OS="macos" ;;
    Linux*)  ADX_OS="linux" ;;
esac

# ---------------------------------------------------------------------------
# Dependency management
# ---------------------------------------------------------------------------
_has() {
    command -v "$1" &>/dev/null
}

_pkg_manager() {
    if _has brew; then echo "brew install"
    elif _has apt; then echo "sudo apt install"
    elif _has dnf; then echo "sudo dnf install"
    elif _has pacman; then echo "sudo pacman -S"
    elif _has apk; then echo "sudo apk add"
    else echo ""
    fi
}

_check_deps() {
    local missing=()
    local install_cmds=()
    local pm=$(_pkg_manager)

    if ! _has adb; then
        missing+=("adb")
        if [[ "$ADX_OS" == "macos" ]]; then
            install_cmds+=("brew install android-platform-tools")
        elif [[ -n "$pm" ]]; then
            install_cmds+=("$pm android-tools")
        fi
    fi

    if ! _has fzf; then
        missing+=("fzf")
        [[ -n "$pm" ]] && install_cmds+=("$pm fzf")
    fi

    if [[ "$ADX_OS" == "macos" ]] && ! _has dns-sd; then
        missing+=("dns-sd")
        install_cmds+=("# dns-sd should be built into macOS — something is wrong")
    fi

    if [[ "$ADX_OS" == "linux" ]] && ! _has avahi-browse; then
        missing+=("avahi-browse")
        [[ -n "$pm" ]] && install_cmds+=("$pm avahi-utils")
    fi

    if [[ ${#missing[@]} -eq 0 ]]; then
        return 0
    fi

    _header "Missing Dependencies"
    for dep in "${missing[@]}"; do
        _error "$dep"
    done

    if [[ ${#install_cmds[@]} -gt 0 ]]; then
        echo ""
        _print "  Install with:"
        for cmd in "${install_cmds[@]}"; do
            _print "    ${CYAN}${cmd}${RESET}"
        done
        echo ""
        printf "  Run now? ${DIM}[Y/n]${RESET} "
        read -r -n 1 answer; echo
        if [[ ! "$answer" =~ ^[Nn]$ ]]; then
            for cmd in "${install_cmds[@]}"; do
                [[ "$cmd" == "#"* ]] && continue
                _info "Running: $cmd"
                eval "$cmd"
            done
            echo ""
            _success "Dependencies installed. Run ${BOLD}adx${RESET} again."
        fi
    else
        _warn "Could not detect package manager. Please install manually."
    fi

    exit 1
}

_check_scrcpy() {
    if ! _has scrcpy; then
        local pm=$(_pkg_manager)
        _error "scrcpy is required for mirror commands"
        echo ""
        if [[ -n "$pm" ]]; then
            _print "  Install with: ${CYAN}$pm scrcpy${RESET}"
            echo ""
            printf "  Run now? ${DIM}[Y/n]${RESET} "
            read -r -n 1 answer; echo
            if [[ ! "$answer" =~ ^[Nn]$ ]]; then
                eval "$pm scrcpy"
                echo ""
                if ! _has scrcpy; then
                    _error "Installation failed."
                    exit 1
                fi
            else
                exit 1
            fi
        else
            _warn "Install scrcpy manually: https://github.com/Genymobile/scrcpy"
            exit 1
        fi
    fi
}

_check_deps

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
_label_for() {
    local target="$1"
    grep "^${target}|" "$ADX_LABELS" 2>/dev/null | cut -d'|' -f2 | head -1 || true
}

_display_name() {
    local target="$1" dname="$2"
    local label
    label=$(_label_for "$target")
    if [[ -n "$label" ]]; then
        echo "$label ($target)"
    elif [[ -n "$dname" ]]; then
        echo "$dname ($target)"
    else
        echo "$target"
    fi
}

_add_history() {
    local target="$1" dname="${2:-}"
    grep -v "^${target}" "$ADX_HISTORY" > "${ADX_HISTORY}.tmp" 2>/dev/null || true
    echo "${target}|${dname}|$(date +%s)" > "${ADX_HISTORY}.new"
    cat "${ADX_HISTORY}.tmp" >> "${ADX_HISTORY}.new"
    mv "${ADX_HISTORY}.new" "$ADX_HISTORY"
    rm -f "${ADX_HISTORY}.tmp"
}

_set_label() {
    local target="$1" label="$2"
    grep -v "^${target}|" "$ADX_LABELS" > "${ADX_LABELS}.tmp" 2>/dev/null || true
    echo "${target}|${label}" >> "${ADX_LABELS}.tmp"
    mv "${ADX_LABELS}.tmp" "$ADX_LABELS"
}

_connected_count() {
    local count
    count=$(adb devices 2>/dev/null | grep -c "device$") || true
    echo "${count:-0}"
}

# ---------------------------------------------------------------------------
# mDNS scanning — platform-aware
# ---------------------------------------------------------------------------
_mdns_browse() {
    local service="$1" duration="${2:-3}"
    local tmpfile
    tmpfile=$(mktemp)

    if [[ "$ADX_OS" == "macos" ]]; then
        dns-sd -B "$service" . > "$tmpfile" 2>&1 &
        local pid=$!
        sleep "$duration"
        kill $pid 2>/dev/null; wait $pid 2>/dev/null
        grep "Add" "$tmpfile" | grep -v "^Timestamp" | awk '{print $NF}'
    else
        avahi-browse -t -p "$service" 2>/dev/null > "$tmpfile" &
        local pid=$!
        sleep "$duration"
        kill $pid 2>/dev/null; wait $pid 2>/dev/null
        grep "^=" "$tmpfile" | cut -d';' -f4 | sort -u
    fi

    rm -f "$tmpfile"
}

_mdns_resolve() {
    local instance="$1" service="$2"
    local tmpfile
    tmpfile=$(mktemp)

    if [[ "$ADX_OS" == "macos" ]]; then
        dns-sd -L "$instance" "$service" local. > "$tmpfile" 2>&1 &
        local pid=$!
        sleep 2
        kill $pid 2>/dev/null; wait $pid 2>/dev/null
        cat "$tmpfile"
    else
        avahi-browse -t -p -r "$service" 2>/dev/null > "$tmpfile" &
        local pid=$!
        sleep 2
        kill $pid 2>/dev/null; wait $pid 2>/dev/null
        local block
        block=$(awk "/=$instance/{found=1} found{print} found && /^$/{exit}" "$tmpfile")
        echo "$block"
    fi

    rm -f "$tmpfile"
}

_mdns_ip() {
    local hostname="$1"

    if [[ "$ADX_OS" == "macos" ]]; then
        local tmpfile
        tmpfile=$(mktemp)
        dns-sd -G v4 "$hostname" > "$tmpfile" 2>&1 &
        local pid=$!
        sleep 2
        kill $pid 2>/dev/null; wait $pid 2>/dev/null
        grep -E '^\d.*Add' "$tmpfile" | awk '{print $6}' | head -1
        rm -f "$tmpfile"
    else
        getent hosts "${hostname%.}" 2>/dev/null | awk '{print $1}' | head -1
    fi
}

_scan_devices() {
    local service="${1:-_adb-tls-connect._tcp}"
    local instances
    instances=($(_mdns_browse "$service"))

    if [[ ${#instances[@]} -eq 0 ]]; then
        return 1
    fi

    for inst in "${instances[@]}"; do
        local lookup host port dname ip
        lookup=$(_mdns_resolve "$inst" "$service")

        if [[ "$ADX_OS" == "macos" ]]; then
            host=$(echo "$lookup" | grep "can be reached" | sed 's/.*at \(.*\):\([0-9]*\) (.*/\1/')
            port=$(echo "$lookup" | grep "can be reached" | sed 's/.*:\([0-9]*\) (.*/\1/')
            dname=$(echo "$lookup" | grep "name=" | sed 's/.*name=\([^ ]*\).*/\1/')
        else
            host=$(echo "$lookup" | grep "^=.*" | cut -d';' -f7 | head -1)
            port=$(echo "$lookup" | grep "^=.*" | cut -d';' -f9 | head -1)
            dname=$(echo "$lookup" | grep -o 'name=[^ ]*' | cut -d= -f2 | head -1)
        fi

        [[ -z "$host" || -z "$port" ]] && continue

        ip=$(_mdns_ip "$host")
        [[ -z "$ip" || "$ip" == "0.0.0.0" ]] && continue

        echo "${ip}:${port}|${dname}"
    done
}

# ---------------------------------------------------------------------------
# Actions
# ---------------------------------------------------------------------------
_get_adb_devices() {
    adb devices -l 2>/dev/null | grep -v "^List\|^$" | while IFS= read -r line; do
        local serial model
        serial=$(echo "$line" | awk '{print $1}')
        model=$(echo "$line" | grep -o 'model:[^ ]*' | cut -d: -f2)
        [[ -z "$serial" ]] && continue
        echo "${serial}|${model:-unknown}"
    done
}

_pick_device() {
    local prompt="${1:-Select device > }"
    local multi="${2:-}"
    local devices=()
    local seen=()

    # Scan in background with spinner
    local scan_tmp
    scan_tmp=$(mktemp)
    _scan_devices > "$scan_tmp" 2>/dev/null &
    local scan_pid=$!

    # Get already-connected devices immediately
    while IFS='|' read -r target dname; do
        [[ -z "$target" ]] && continue
        local display
        display=$(_display_name "$target" "$dname")
        local tag="wifi"
        [[ "$target" != *":"* ]] && tag="usb"
        devices+=("${display} [${tag}]|${target}|${dname}")
        seen+=("$target")
    done < <(_get_adb_devices)

    # Wait for mDNS scan with spinner
    _spinner $scan_pid "Auto-scanning for paired devices..."

    # Add mDNS-discovered devices
    while IFS='|' read -r target dname; do
        [[ -z "$target" ]] && continue
        local already=0
        for s in ${seen[@]+"${seen[@]}"}; do
            [[ "$s" == "$target" ]] && { already=1; break; }
        done
        [[ $already -eq 1 ]] && continue
        local display
        display=$(_display_name "$target" "$dname")
        devices+=("${display} [wifi]|${target}|${dname}")
    done < "$scan_tmp"
    rm -f "$scan_tmp"

    if [[ ${#devices[@]} -gt 0 ]]; then
        _success "Found ${BOLD}${#devices[@]}${RESET} device(s)" >&2
    fi

    # fzf with --print-query: user can type IP:port OR pick a scanned device
    local fzf_input=""
    if [[ ${#devices[@]} -gt 0 ]]; then
        fzf_input=$(printf '%s\n' "${devices[@]}" | cut -d'|' -f1)
    fi

    # Build header based on whether devices were found
    local fzf_header
    if [[ ${#devices[@]} -gt 0 ]]; then
        fzf_header="Enter IP:port (e.g. 192.168.1.5:37000) or select a device"
    else
        fzf_header="$(printf '%s\n%s' \
            "No paired devices found. Enter IP:port to connect manually" \
            "  → Find it: Settings > Developer Options > Wireless Debugging > IP address & Port")"
    fi

    local fzf_height=$(( ${#devices[@]} + 6 ))
    [[ $fzf_height -lt 10 ]] && fzf_height=10
    local fzf_opts=(
        --height=$fzf_height --layout=reverse --no-info --no-sort
        --print-query
        --prompt="$prompt"
        --header="$fzf_header"
        --color=pointer:green,header:dim
    )
    [[ -n "$multi" ]] && fzf_opts+=(--multi)

    local fzf_out query selected
    fzf_out=$(printf '%s' "$fzf_input" | fzf "${fzf_opts[@]}") || {
        # fzf exits 1 on no match — check if user typed a valid IP
        query=$(echo "$fzf_out" | head -1)
        if [[ -n "$query" && "$query" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+(:[0-9]+)?$ ]]; then
            local manual_target="$query"
            [[ "$manual_target" != *":"* ]] && manual_target="${manual_target}:5555"
            echo "${manual_target}|manual"
            return 0
        fi
        return 1
    }

    # --print-query: line 1 = typed query, remaining lines = selected item(s)
    query=$(echo "$fzf_out" | head -1)
    selected=$(echo "$fzf_out" | tail -n +2)

    # User selected a scanned device
    if [[ -n "$selected" ]]; then
        local results=()
        while IFS= read -r sel; do
            for d in "${devices[@]}"; do
                local display target dname
                display=$(echo "$d" | cut -d'|' -f1)
                target=$(echo "$d" | cut -d'|' -f2)
                dname=$(echo "$d" | cut -d'|' -f3)
                if [[ "$display" == "$sel" ]]; then
                    results+=("${target}|${dname}")
                fi
            done
        done <<< "$selected"
        printf '%s\n' "${results[@]}"
        return 0
    fi

    # No selection — check if query is a manual IP:port
    if [[ -n "$query" && "$query" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+(:[0-9]+)?$ ]]; then
        local manual_target="$query"
        [[ "$manual_target" != *":"* ]] && manual_target="${manual_target}:5555"
        echo "${manual_target}|manual"
        return 0
    fi

    return 1
}

_do_inline_pair() {
    local known_ip="${1:-}"
    _info "Device needs to be paired first (one-time setup)"
    _info "On your device: ${BOLD}Settings > Developer Options > Wireless Debugging > Pair device with pairing code${RESET}"
    echo ""
    local pair_target
    if [[ -n "$known_ip" && "${BASH_VERSINFO[0]}" -ge 4 ]]; then
        # bash 4+: editable prefill
        printf "  Pairing IP:port ${DIM}(e.g. 192.168.1.5:37869)${RESET}: " >&2
        read -r -e -i "${known_ip}:" pair_target </dev/tty
    else
        local hint="e.g. 192.168.1.5:37869"
        [[ -n "$known_ip" ]] && hint="e.g. ${known_ip}:37869"
        printf "  Pairing IP:port ${DIM}(${hint})${RESET}: " >&2
        read -r pair_target </dev/tty
    fi
    [[ -z "$pair_target" ]] && { _error "No address provided"; return 1; }
    if [[ ! "$pair_target" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+:[0-9]+$ ]]; then
        _error "Invalid format. Enter the full IP:port (e.g. 192.168.1.5:37869)"
        return 1
    fi
    printf "  Pairing code ${DIM}(6 digits shown on device)${RESET}: " >&2
    read -r pair_code </dev/tty
    [[ -z "$pair_code" ]] && { _error "No code provided"; return 1; }

    local result
    result=$(adb pair "$pair_target" "$pair_code" 2>&1)
    if echo "$result" | grep -qi "success"; then
        _success "Paired successfully!"
        return 0
    else
        _error "Pairing failed: $result"
        return 1
    fi
}

_connect() {
    local target="$1" dname="${2:-}"
    if [[ "$target" == *":"* ]]; then
        local result
        result=$(adb connect "$target" 2>&1)
        if echo "$result" | grep -q "connected"; then
            _success "Connected to ${BOLD}${dname:-$target}${RESET} ${DIM}($target)${RESET}"
        else
            _error "Failed to connect to ${BOLD}$target${RESET}"
            _info "$result"
            echo ""
            printf "  Pair this device? [y/N] " >&2
            local yn
            read -r yn </dev/tty
            if [[ "$yn" =~ ^[Yy]$ ]]; then
                echo ""
                local connect_ip="${target%%:*}"
                _do_inline_pair "$connect_ip" || return 1
                echo ""
                _info "Retrying connection..."
                result=$(adb connect "$target" 2>&1)
                if echo "$result" | grep -q "connected"; then
                    _success "Connected to ${BOLD}${dname:-$target}${RESET} ${DIM}($target)${RESET}"
                else
                    _error "Still could not connect: $result"
                    _info "Make sure the IP:port is from the Wireless Debugging screen (not the pairing port)"
                    return 1
                fi
            else
                _info "Check that Wireless Debugging is enabled and the IP:port is correct"
                return 1
            fi
        fi
        _add_history "$target" "$dname"
    else
        _success "Using USB device ${BOLD}${dname:-$target}${RESET}"
    fi
}

_do_scan_connect() {
    local multi="${1:-}"
    local picked
    picked=$(_pick_device "Connect > " "$multi") || return 1

    while IFS='|' read -r target dname; do
        _connect "$target" "$dname" || return 1
    done <<< "$picked"
}

_do_scan_mirror() {
    _check_scrcpy
    local picked
    picked=$(_pick_device "Mirror > ") || return 1

    local target dname
    target=$(echo "$picked" | head -1 | cut -d'|' -f1)
    dname=$(echo "$picked" | head -1 | cut -d'|' -f2)

    _connect "$target" "$dname" || return 1
    sleep 1
    _success "Launching scrcpy..."
    scrcpy -s "$target" &>/dev/null &
    disown
}

_do_reconnect() {
    local mirror="${1:-}"
    if [[ ! -s "$ADX_HISTORY" ]]; then
        _warn "No connection history"
        return 1
    fi

    [[ "$mirror" == "mirror" ]] && _check_scrcpy

    local entries=()
    while IFS='|' read -r target dname ts; do
        local display
        display=$(_display_name "$target" "$dname")
        entries+=("$display")
    done < "$ADX_HISTORY"

    local selected
    selected=$(printf '%s\n' "${entries[@]}" | fzf --height=$((${#entries[@]} + 2)) --layout=reverse --no-info --no-sort --prompt="Reconnect > " --no-scrollbar --color=pointer:green)
    [[ -z "$selected" ]] && return 0

    local target
    target=$(echo "$selected" | grep -o '[0-9.]*:[0-9]*')
    [[ -z "$target" ]] && { _error "Could not parse address"; return 1; }

    _connect "$target" || return 1

    if [[ "$mirror" == "mirror" ]]; then
        sleep 1
        _success "Launching scrcpy..."
        scrcpy -s "$target" &>/dev/null &
        disown
    fi
}

_do_status() {
    _header "Connected Devices"

    local count=0
    while IFS= read -r line; do
        local serial status model product transport
        serial=$(echo "$line" | awk '{print $1}')
        status=$(echo "$line" | awk '{print $2}')
        model=$(echo "$line" | grep -o 'model:[^ ]*' | cut -d: -f2)
        product=$(echo "$line" | grep -o 'product:[^ ]*' | cut -d: -f2)

        [[ -z "$serial" ]] && continue
        count=$((count + 1))

        local label
        label=$(_label_for "$serial")
        local name="${label:-${model:-unknown}}"

        local type_tag="${BLUE}wifi${RESET}"
        [[ "$serial" != *":"* ]] && type_tag="${GREEN}usb${RESET}"

        local status_color="${GREEN}"
        [[ "$status" != "device" ]] && status_color="${YELLOW}"

        printf "  ${BOLD}${WHITE}%-20s${RESET} ${DIM}%-25s${RESET} [${type_tag}] ${status_color}${status}${RESET}\n" "$name" "$serial"
    done < <(adb devices -l 2>/dev/null | grep -v "^List\|^$")

    if [[ $count -eq 0 ]]; then
        _info "No devices connected"
    else
        echo ""
        _info "$count device(s) connected"
    fi
}

_do_disconnect() {
    local connected
    connected=$(adb devices | grep -v "^List\|^$" | awk '{print $1}')
    if [[ -z "$connected" ]]; then
        _warn "No connected devices"
        return 0
    fi

    local entries=("Disconnect all")
    while IFS= read -r dev; do
        local label
        label=$(_label_for "$dev")
        if [[ -n "$label" ]]; then
            entries+=("$label ($dev)")
        else
            entries+=("$dev")
        fi
    done <<< "$connected"

    local fzf_height=$((${#entries[@]} + 2))
    [[ $fzf_height -lt 10 ]] && fzf_height=10

    local selected
    selected=$(printf '%s\n' "${entries[@]}" | fzf --height=$fzf_height --layout=reverse --no-info --no-sort --prompt="Disconnect > " --color=pointer:green)
    [[ -z "$selected" ]] && return 0

    if [[ "$selected" == "Disconnect all" ]]; then
        adb disconnect &>/dev/null
        _success "Disconnected all devices"
    else
        local target
        target=$(echo "$selected" | grep -o '[0-9.]*:[0-9]*')
        if [[ -n "$target" ]]; then
            adb disconnect "$target" &>/dev/null
            _success "Disconnected ${BOLD}$target${RESET}"
        else
            adb disconnect "$selected" &>/dev/null
            _success "Disconnected ${BOLD}$selected${RESET}"
        fi
    fi
}

_do_label() {
    # Show connected devices for easy picking
    local connected
    connected=$(adb devices | grep -v "^List\|^$" | awk '{print $1}')

    if [[ -n "$connected" ]]; then
        local entries=()
        while IFS= read -r dev; do
            entries+=("$dev")
        done <<< "$connected"

        local selected
        selected=$(printf '%s\n' "${entries[@]}" | fzf --height=$((${#entries[@]} + 2)) --layout=reverse --no-info --no-sort --prompt="Label which device > " --no-scrollbar --color=pointer:green)

        if [[ -n "$selected" ]]; then
            printf "  Label for ${BOLD}${selected}${RESET}: "
            read -r label
            [[ -z "$label" ]] && return 1
            _set_label "$selected" "$label"
            _success "Labeled ${BOLD}$selected${RESET} as ${CYAN}$label${RESET}"
            return 0
        fi
    fi

    printf "  IP:Port: "
    read -r target
    [[ -z "$target" ]] && return 1
    printf "  Label: "
    read -r label
    [[ -z "$label" ]] && return 1
    _set_label "$target" "$label"
    _success "Labeled ${BOLD}$target${RESET} as ${CYAN}$label${RESET}"
}

# ---------------------------------------------------------------------------
# Update check + self-update
# ---------------------------------------------------------------------------
ADX_LAST_CHECK="${ADX_DIR}/last_update_check"
ADX_LATEST_CACHE="${ADX_DIR}/latest_version"

_check_for_update() {
    _has curl || return 0

    local now
    now=$(date +%s)
    local last_check=0
    [[ -f "$ADX_LAST_CHECK" ]] && last_check=$(cat "$ADX_LAST_CHECK" 2>/dev/null || echo 0)
    local elapsed=$((now - last_check))

    [[ $elapsed -lt 86400 ]] && {
        if [[ -f "$ADX_LATEST_CACHE" ]]; then
            local cached
            cached=$(cat "$ADX_LATEST_CACHE")
            [[ -n "$cached" && "$cached" != "$ADX_VERSION" ]] && _warn "adx ${BOLD}v${cached}${RESET} available — run ${CYAN}adx upgrade${RESET} to update" >&2
        fi
        return 0
    }

    (
        local latest
        latest=$(curl -fsSL --connect-timeout 3 "https://api.github.com/repos/${ADX_REPO}/releases/latest" 2>/dev/null | grep '"tag_name"' | sed 's/.*"v\([^"]*\)".*/\1/')
        if [[ -n "$latest" ]]; then
            echo "$now" > "$ADX_LAST_CHECK"
            echo "$latest" > "$ADX_LATEST_CACHE"
            [[ "$latest" != "$ADX_VERSION" ]] && _warn "adx ${BOLD}v${latest}${RESET} available — run ${CYAN}adx upgrade${RESET} to update" >&2
        fi
    ) &
    disown
}

_fetch_latest_version() {
    curl -fsSL "https://api.github.com/repos/${ADX_REPO}/releases/latest" 2>/dev/null | grep '"tag_name"' | sed 's/.*"v\([^"]*\)".*/\1/'
}

_fetch_all_versions() {
    curl -fsSL "https://api.github.com/repos/${ADX_REPO}/releases" 2>/dev/null | grep '"tag_name"' | sed 's/.*"v\([^"]*\)".*/\1/'
}

_install_version() {
    local version="$1"
    local self_path
    self_path=$(realpath "$0" 2>/dev/null || readlink -f "$0" 2>/dev/null || echo "$0")
    local download_url="https://raw.githubusercontent.com/${ADX_REPO}/v${version}/bin/adx"

    local tmpfile
    tmpfile=$(mktemp)
    curl -fsSL "$download_url" -o "$tmpfile" &
    local dl_pid=$!
    _spinner $dl_pid "Downloading v${version}..."

    if ! wait $dl_pid; then
        rm -f "$tmpfile"
        _error "Download failed"
        return 1
    fi

    chmod +x "$tmpfile"
    chmod u+w "$self_path" 2>/dev/null || true

    if cp "$tmpfile" "$self_path" 2>/dev/null; then
        _success "Switched to ${BOLD}v${version}${RESET}"
    elif sudo cp "$tmpfile" "$self_path"; then
        _success "Switched to ${BOLD}v${version}${RESET}"
    else
        _error "Could not write to $self_path"
        _info "Try: sudo cp $tmpfile $self_path"
        return 1
    fi

    rm -f "$tmpfile"
    echo "$version" > "$ADX_LATEST_CACHE"
    echo "$(date +%s)" > "$ADX_LAST_CHECK"
    exit 0
}

_do_upgrade() {
    if ! _has curl; then
        _error "curl is required for upgrades"
        return 1
    fi

    if [[ "${1:-}" == "--list" ]]; then
        local versions_tmp
        versions_tmp=$(mktemp)
        _fetch_all_versions > "$versions_tmp" &
        local fetch_pid=$!
        _spinner $fetch_pid "Fetching versions..."

        local versions
        versions=($(cat "$versions_tmp"))
        rm -f "$versions_tmp"

        if [[ ${#versions[@]} -eq 0 ]]; then
            _error "Could not fetch versions. Are you online?"
            return 1
        fi

        local display=()
        for v in "${versions[@]}"; do
            if [[ "$v" == "$ADX_VERSION" ]]; then
                display+=("$v ${GREEN}(current)${RESET}")
            else
                display+=("$v")
            fi
        done

        local selected
        selected=$(printf '%s\n' "${display[@]}" | fzf --height=$((${#display[@]} + 2)) --layout=reverse --no-info --no-sort --prompt="Version > " --no-scrollbar --color=pointer:green --ansi)
        [[ -z "$selected" ]] && return 0

        local target_version
        target_version=$(echo "$selected" | awk '{print $1}')

        if [[ "$target_version" == "$ADX_VERSION" ]]; then
            _info "Already on v${ADX_VERSION}"
            return 0
        fi

        echo ""
        _print "  Current: ${DIM}$ADX_VERSION${RESET}"
        _print "  Target:  ${BOLD}$target_version${RESET}"
        echo ""
        printf "  Switch? ${DIM}[Y/n]${RESET} "
        read -r -n 1 answer; echo
        [[ "$answer" =~ ^[Nn]$ ]] && return 0

        _install_version "$target_version"
        return $?
    fi

    local latest_tmp
    latest_tmp=$(mktemp)
    _fetch_latest_version > "$latest_tmp" &
    local fetch_pid=$!
    _spinner $fetch_pid "Checking for updates..."

    local latest
    latest=$(cat "$latest_tmp")
    rm -f "$latest_tmp"

    if [[ -z "$latest" ]]; then
        _error "Could not check for updates. Are you online?"
        return 1
    fi

    if [[ "$latest" == "$ADX_VERSION" ]]; then
        _success "Already on latest ${DIM}(v${ADX_VERSION})${RESET}"
        return 0
    fi

    _print "  Current: ${DIM}$ADX_VERSION${RESET}"
    _print "  Latest:  ${GREEN}${BOLD}$latest${RESET}"
    echo ""
    printf "  Upgrade? ${DIM}[Y/n]${RESET} "
    read -r -n 1 answer; echo
    [[ "$answer" =~ ^[Nn]$ ]] && return 0

    _install_version "$latest"
}

# ---------------------------------------------------------------------------
# Banner
# ---------------------------------------------------------------------------
_banner() {
    local count
    count=$(_connected_count)
    local count_text="${count} device(s) connected"
    local count_color="${GREEN}"
    [[ $count -eq 0 ]] && count_color="${DIM}"

    printf "\n"
    printf "  ${BOLD}${CYAN}adx${RESET} ${DIM}v${ADX_VERSION}${RESET}  ${DIM}—${RESET}  ${count_color}${count_text}${RESET}\n"
    printf "  ${DIM}Android Developer eXperience${RESET}\n"
    printf "\n"
}

# ---------------------------------------------------------------------------
# Main menu
# ---------------------------------------------------------------------------
_build_menu() {
    local last_target="" last_label=""
    if [[ -s "$ADX_HISTORY" ]]; then
        IFS='|' read -r last_target last_label _ < "$ADX_HISTORY"
    fi

    local reconnect_hint=""
    [[ -n "$last_label" ]] && reconnect_hint=" → $last_label"
    [[ -z "$reconnect_hint" && -n "$last_target" ]] && reconnect_hint=" → $last_target"

    # Build menu with section headers
    printf "${BOLD}CONNECT${RESET}\n"
    printf "  Scan & Connect\n"
    printf "  Scan & Mirror\n"

    if [[ -n "$last_target" ]]; then
        printf "${BOLD}QUICK${RESET}\n"
        printf "  Reconnect${DIM}${reconnect_hint}${RESET}\n"
        printf "  Reconnect & Mirror${DIM}${reconnect_hint}${RESET}\n"
    fi

    printf "${BOLD}MANAGE${RESET}\n"
    printf "  Status\n"
    printf "  Disconnect\n"
    printf "  Label Device\n"

    printf "${BOLD}SYSTEM${RESET}\n"

    local update_hint=""
    if [[ -f "$ADX_LATEST_CACHE" ]]; then
        local cached
        cached=$(cat "$ADX_LATEST_CACHE")
        [[ -n "$cached" && "$cached" != "$ADX_VERSION" ]] && update_hint=" ${YELLOW}(v${cached} available)${RESET}"
    fi
    printf "  Upgrade${update_hint}\n"
    printf "  ${DIM}Exit${RESET}\n"
}

_main() {
    if [[ "${1:-}" == "--version" || "${1:-}" == "-v" ]]; then
        echo "adx $ADX_VERSION"
        return 0
    fi

    if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
        _print ""
        _print "  ${BOLD}${CYAN}adx${RESET} — Android Developer eXperience"
        _print ""
        _print "  ${BOLD}Usage:${RESET} adx ${DIM}[command]${RESET}"
        _print ""
        _print "  ${BOLD}Commands:${RESET}"
        _print "    ${CYAN}scan${RESET}            Scan & connect to a device"
        _print "    ${CYAN}mirror${RESET}          Scan, connect & launch scrcpy"
        _print "    ${CYAN}reconnect${RESET}       Reconnect to a previous device"
        _print "    ${CYAN}remirror${RESET}        Reconnect & launch scrcpy"
        _print "    ${CYAN}status${RESET}          Show connected devices"
        _print "    ${CYAN}disconnect${RESET}      Disconnect devices"
        _print "    ${CYAN}label${RESET}           Assign a friendly name to a device"
        _print "    ${CYAN}upgrade${RESET}         Update to the latest version"
        _print "    ${CYAN}upgrade --list${RESET}  Pick any version to install"
        _print ""
        _print "  Run without arguments for interactive menu."
        _print ""
        return 0
    fi

    _check_for_update

    local cmd="${1:-}"

    if [[ -n "$cmd" ]]; then
        case "$cmd" in
            scan)       _do_scan_connect ;;
            mirror)     _do_scan_mirror ;;
            reconnect)  _do_reconnect ;;
            remirror)   _do_reconnect mirror ;;
            status)     _do_status ;;
            disconnect) _do_disconnect ;;
            label)      _do_label ;;
            upgrade)    shift; _do_upgrade "$@" ;;
            *)          _error "Unknown command: $cmd"; _info "Run 'adx --help' for usage"; return 1 ;;
        esac
        return $?
    fi

    while true; do
        _banner

        local choice
        choice=$(_build_menu | fzf --height=20 --layout=reverse --no-info --no-sort --prompt="  " --no-scrollbar --color=pointer:green --ansi --delimiter='\n')

        [[ -z "$choice" ]] && continue

        # Strip ANSI codes, leading spaces, hints for matching
        local clean
        clean=$(echo "$choice" | sed "s/$(printf '\033')\[[0-9;]*m//g" | sed 's/^  //' | sed 's/ →.*//' | sed 's/ (.*//')

        echo ""

        case "$clean" in
            "Scan & Connect")       _do_scan_connect ;;
            "Scan & Mirror")        _do_scan_mirror ;;
            "Reconnect")            _do_reconnect ;;
            "Reconnect & Mirror")   _do_reconnect mirror ;;
            "Status")               _do_status ;;
            "Disconnect")           _do_disconnect ;;
            "Label Device")         _do_label ;;
            "Upgrade")              _do_upgrade ;;
            "Exit")                 return 0 ;;
            CONNECT|QUICK|MANAGE|SYSTEM) continue ;;
            *)                      continue ;;
        esac

        echo ""
        printf "  ${DIM}Press any key to continue...${RESET}"
        read -r -n 1 -s; echo
    done
}

_main "$@"
